struct Clanes {
    int IDClan;
    string nombreClan;
    string region;
    int cantidadMiembros;
    int puntajeClan;
    Clanes *sig;

    Clanes(int i, string n, string r, int c, int p) {
        IDClan = i;
        nombreClan = n;
        region = r;
        cantidadMiembros = c;
        puntajeClan = p;

        sig = nullptr;

    }
};
Clanes* inicioClanes = nullptr;
void insertarClanCircularFinal(int i, string n, string r, int c, int p) {
    Clanes* nuevo = new Clanes(i, n, r, c, p);
    if (inicioClanes == nullptr) {
        inicioClanes = nuevo;
        nuevo->sig = inicioClanes;
    } else {
        Clanes* aux = inicioClanes;
        while (aux->sig != inicioClanes) {
            aux = aux->sig;
        }
        aux->sig = nuevo;
        nuevo->sig = inicioClanes;
    }
    cout << "Clan guardado (Circular)" << endl;
}

