struct Jugador {
    int idJugador;
    string nombreUsuario;
    int nivelRey;
    int trofeos;
    int idArena;
    int idClan;

    Jugador *sig, *ant;

    Jugador(int j, string n, int r, int t, int a, int c) {
        idJugador = j;
        nombreUsuario = n;
        nivelRey = r;
        trofeos = t;
        idArena = a;
        idClan = c;
        sig = nullptr;
        ant = nullptr;
    }
};

Jugador *primerJugador = nullptr;

void insertarJugador(int idJugador, string nombreUsuario, int nivelRey, int trofeos, int idArena, int idClan) {
    Jugador *nuevoJugador = new Jugador(idJugador, nombreUsuario, nivelRey, trofeos, idArena, idClan);
    if (primerJugador == nullptr) {
        primerJugador = nuevoJugador;
    } else {
        Jugador *temp = primerJugador;
        while (temp->sig != nullptr)
            temp = temp->sig;
        temp->sig = nuevoJugador;
        nuevoJugador->ant = temp;
    }
}

Jugador* buscarJugadorID(int IDJugador) {
    Jugador *temp = primerJugador;
    while (temp) {
        if (temp->idJugador == IDJugador)
            return temp;
        temp = temp->sig;
    }
    return nullptr;
}

void modificarJugadorNombre(int IDJugador, string nombreAnterior, string nuevoNombre) {
    Jugador *temp = buscarJugadorID(IDJugador);
    if (!temp) {
        cout << "Jugador no existente"<<endl;
        return;
    }
    if (temp->nombreUsuario == nombreAnterior) {
        temp->nombreUsuario = nuevoNombre;
        cout << "Nombre modificado"<<endl;
    } else {
        cout << "El nombre anterior no coincide"<<endl;
    }
}

void modificarJugadorNivelRey(int IDJugador, int nuevoNivel) {
    Jugador *temp = buscarJugadorID(IDJugador);
    if (!temp) {
        cout << "Jugador no existente"<<endl;
        return;
    }
    temp->nivelRey = nuevoNivel;
    cout << "Nivel de rey actualizado"<<endl;
}

void modificarJugadorTrofeos(int IDJugador, int nuevosTrofeos) {
    Jugador *temp = buscarJugadorID(IDJugador);
