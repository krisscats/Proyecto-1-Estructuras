//Funciones auxiliares de Clan

//Verifica si la lista está vacía
bool listaVaciaClan() {
    return inicioClan == nullptr;
}

//Devuelve el último nodo de la lista circular
Clanes* obtenerUltimoClan() {
    if (listaVaciaClan()) {
        return nullptr;
    }

    Clanes* temp = inicioClan;

    while (temp->sig != inicioClan) {
        temp = temp->sig;
    }

    return temp;
}

Clanes* buscarClanPorId(int idClan) {
    if (listaVaciaClan()) {
        return nullptr;
    }

    Clanes* temp = inicioClan;

    do {
        if (temp->idClan == idClan) {
            return temp;
        }
        temp = temp->sig;
    } while (temp != inicioClan);

    return nullptr;
}

bool existeClan(int idClan) {
    return buscarClanPorId(idClan) != nullptr;
}

void imprimirClan(Clanes* c) {
    if (c == nullptr) {
        cout << "El clan no existe" << endl;
